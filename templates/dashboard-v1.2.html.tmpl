<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ meta.primary_symbol }} — {{ meta.report_title }}</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
  :root {
    --color-bg-base: #0d1117;
    --color-bg-surface: #161b22;
    --color-bg-elevated: #1c2128;
    --color-bg-hover: #21262d;
    --color-border-subtle: #30363d;
    --color-border-muted: #21262d;
    --color-text-primary: #e6edf3;
    --color-text-secondary: #8b949e;
    --color-text-tertiary: #6e7681;
    --color-accent: #58a6ff;
    --color-bull: #26a69a;
    --color-bear: #ef5350;
    --color-warning: #d29922;
    --color-target-bg: rgba(88, 166, 255, 0.08);
    --color-target-border: #58a6ff;
    --color-layer-facts: #8b949e;
    --color-layer-insights: #58a6ff;
    --color-layer-analysis: #d29922;
    --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --font-mono: 'JetBrains Mono', 'SF Mono', Menlo, Consolas, monospace;
    --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
    --space-5: 24px; --space-6: 32px; --space-7: 48px;
    --radius-sm: 4px; --radius-md: 6px; --radius-lg: 8px;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: var(--color-bg-base);
    color: var(--color-text-primary);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  .container { max-width: 1280px; margin: 0 auto; padding: var(--space-5); }
  @media (max-width: 600px) {
    .container { padding: var(--space-4) var(--space-3); }
    html, body { font-size: 13px; }
  }

  .top-bar { padding: var(--space-3) 0; margin-bottom: var(--space-4); border-bottom: 1px solid var(--color-border-muted); }
  .back-link { font-family: var(--font-mono); font-size: 12px; color: var(--color-text-tertiary); text-decoration: none; }
  .back-link:hover { color: var(--color-accent); }

  header { border-bottom: 1px solid var(--color-border-subtle); padding-bottom: var(--space-5); margin-bottom: var(--space-6); display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: var(--space-4); }
  .symbol-badge { font-family: var(--font-mono); font-size: 11px; font-weight: 600; letter-spacing: 0.06em; color: var(--color-accent); background: rgba(88, 166, 255, 0.1); border: 1px solid rgba(88, 166, 255, 0.25); border-radius: var(--radius-sm); padding: 2px 8px; display: inline-block; margin-bottom: var(--space-2); }
  .report-title { font-size: 28px; font-weight: 600; letter-spacing: -0.02em; margin-bottom: var(--space-1); }
  .report-meta { font-size: 12px; color: var(--color-text-tertiary); font-family: var(--font-mono); }
  .header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; }
  .date-label { font-family: var(--font-mono); font-size: 13px; color: var(--color-text-secondary); }
  @media (max-width: 600px) {
    .report-title { font-size: 22px; }
    .header-right { align-items: flex-start; }
    header { gap: var(--space-2); }
  }

  .overview-section { margin-bottom: var(--space-6); }
  .section-title { font-size: 11px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-tertiary); margin-bottom: var(--space-4); padding-bottom: var(--space-2); border-bottom: 1px solid var(--color-border-muted); }
  .market-description { color: var(--color-text-secondary); line-height: 1.7; }

  .layer-section { margin-bottom: var(--space-7); padding-top: var(--space-5); border-top: 2px solid var(--color-border-subtle); position: relative; }
  .layer-section::before { content: ''; position: absolute; top: -2px; left: 0; width: 80px; height: 2px; background: var(--layer-color, var(--color-text-tertiary)); }
  .layer-section.layer-facts { --layer-color: var(--color-layer-facts); }
  .layer-section.layer-insights { --layer-color: var(--color-layer-insights); }
  .layer-section.layer-analysis { --layer-color: var(--color-layer-analysis); }
  .layer-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-5); flex-wrap: wrap; gap: var(--space-2); }
  .layer-tag { font-family: var(--font-mono); font-size: 11px; font-weight: 700; letter-spacing: 0.12em; padding: 4px var(--space-3); border-radius: var(--radius-md); border: 1px solid var(--layer-color); color: var(--layer-color); background: rgba(255,255,255,0.02); text-transform: uppercase; }
  .layer-subtitle { font-size: 11px; color: var(--color-text-tertiary); font-family: var(--font-mono); letter-spacing: 0.04em; }
  .subsection { margin-bottom: var(--space-5); }
  .subsection:last-child { margin-bottom: 0; }
  .subsection-title { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-tertiary); margin-bottom: var(--space-3); }

  /* Metric Cards */
  .metrics-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: var(--space-3); }
  @media (max-width: 600px) { .metrics-grid { grid-template-columns: repeat(2, 1fr); gap: var(--space-2); } }
  .metric-card { background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-md); padding: var(--space-4); display: flex; flex-direction: column; gap: var(--space-1); }
  @media (max-width: 600px) { .metric-card { padding: var(--space-3); } }
  .metric-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-tertiary); }
  .metric-value { font-family: var(--font-mono); font-size: 22px; font-weight: 600; color: var(--color-text-primary); }
  .metric-value.small { font-size: 15px; letter-spacing: -0.01em; }
  .metric-sub { font-family: var(--font-mono); font-size: 11px; color: var(--color-text-tertiary); }
  .metric-comparison { margin-top: var(--space-1); padding-top: var(--space-2); border-top: 1px dashed var(--color-border-muted); display: flex; align-items: center; justify-content: space-between; gap: var(--space-2); font-size: 11px; font-family: var(--font-mono); flex-wrap: wrap; }
  .comparison-label { color: var(--color-text-tertiary); }
  .comparison-value-block { display: flex; align-items: baseline; gap: var(--space-2); }
  .comparison-value { color: var(--color-text-secondary); }
  .comparison-delta { font-weight: 600; }
  .bull { color: var(--color-bull); }
  .bear { color: var(--color-bear); }
  .warn { color: var(--color-warning); }

  /* Charts */
  .chart-wrapper { background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-md); padding: var(--space-4); height: 280px; position: relative; min-width: 0; overflow: hidden; }
  .chart-wrapper canvas { display: block; max-width: 100%; }
  .chart-section { margin-bottom: 0; min-width: 0; }
  .card-title { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-tertiary); margin-bottom: var(--space-2); }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
  .two-col > * { min-width: 0; }
  @media (max-width: 880px) { .two-col { grid-template-columns: 1fr; } }
  @media (max-width: 600px) { .chart-wrapper { height: 240px; padding: var(--space-3); } }

  /* Comparing table - 横スクロール */
  .table-wrapper { overflow-x: auto; -webkit-overflow-scrolling: touch; background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-md); }
  .table-wrapper::-webkit-scrollbar { height: 6px; }
  .table-wrapper::-webkit-scrollbar-track { background: var(--color-bg-elevated); }
  .table-wrapper::-webkit-scrollbar-thumb { background: var(--color-border-subtle); border-radius: 3px; }
  .issues-table { width: 100%; border-collapse: collapse; min-width: 720px; }
  .issues-table th { text-align: left; padding: var(--space-3) var(--space-4); font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-tertiary); background: var(--color-bg-elevated); border-bottom: 1px solid var(--color-border-subtle); white-space: nowrap; }
  .issues-table td { padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-border-muted); font-size: 13px; vertical-align: top; }
  .issues-table tr:last-child td { border-bottom: none; }
  .issues-table tr.role-target { background: var(--color-target-bg); border-left: 2px solid var(--color-target-border); }
  .issues-table tr.role-target td:first-child { font-weight: 600; }
  .role-tag { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-right: var(--space-2); }
  .role-tag.target { background: var(--color-accent); color: var(--color-bg-base); }
  .role-tag.peer { background: var(--color-bg-elevated); color: var(--color-text-tertiary); border: 1px solid var(--color-border-subtle); }
  .symbol-mono { font-family: var(--font-mono); color: var(--color-text-secondary); font-size: 12px; white-space: nowrap; }
  .num-mono { font-family: var(--font-mono); text-align: right; white-space: nowrap; }
  .features-cell { color: var(--color-text-secondary); min-width: 240px; }
  .products-cell { color: var(--color-text-primary); font-family: var(--font-mono); font-size: 12px; min-width: 140px; }
  .growth-cell { font-family: var(--font-mono); text-align: right; font-weight: 600; white-space: nowrap; }
  .unit { color: var(--color-text-tertiary); margin-left: 2px; font-size: 11px; }

  .scroll-hint { display: none; font-family: var(--font-mono); font-size: 10px; color: var(--color-text-tertiary); margin-top: var(--space-1); letter-spacing: 0.06em; }
  @media (max-width: 720px) { .scroll-hint { display: block; } }

  /* Highlights */
  .highlights-card { background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-md); padding: var(--space-5); }
  @media (max-width: 600px) { .highlights-card { padding: var(--space-4) var(--space-3); } }
  .highlights-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); }
  .highlight-item { font-size: 13px; padding: var(--space-3) var(--space-4); padding-left: var(--space-5); position: relative; border-radius: var(--radius-sm); border-left: 2px solid transparent; background: rgba(255, 255, 255, 0.01); }
  .highlight-item .level-marker { position: absolute; left: var(--space-3); top: var(--space-3); font-family: var(--font-mono); font-weight: 700; font-size: 12px; }
  .highlight-item.level-info { border-left-color: var(--color-accent); background: rgba(88, 166, 255, 0.04); }
  .highlight-item.level-info .level-marker { color: var(--color-accent); }
  .highlight-item.level-warning { border-left-color: var(--color-warning); background: rgba(210, 153, 34, 0.05); }
  .highlight-item.level-warning .level-marker { color: var(--color-warning); }
  .highlight-item.level-danger { border-left-color: var(--color-bear); background: rgba(239, 83, 80, 0.05); }
  .highlight-item.level-danger .level-marker { color: var(--color-bear); }
  .highlight-name { color: var(--color-text-primary); font-weight: 600; margin-right: var(--space-1); }
  .highlight-text { color: var(--color-text-secondary); }

  /* Scores */
  .scores-card { background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-md); padding: var(--space-5); }
  @media (max-width: 600px) { .scores-card { padding: var(--space-4) var(--space-3); } }
  .scores-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); }
  @media (max-width: 880px) { .scores-grid { grid-template-columns: 1fr; gap: var(--space-3); } }
  .score-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-2); font-size: 12px; }
  .score-label { color: var(--color-text-tertiary); font-family: var(--font-mono); }
  .score-val { font-family: var(--font-mono); font-weight: 600; }
  .bar-track { height: 6px; background: var(--color-bg-elevated); border-radius: 3px; margin-bottom: var(--space-3); overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 3px; transition: width 0.4s ease; }

  /* Forecast */
  .forecast-card { background: var(--color-bg-surface); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-md); padding: var(--space-5); margin-bottom: var(--space-4); }
  @media (max-width: 600px) { .forecast-card { padding: var(--space-4) var(--space-3); } }
  .forecast-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-4); padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-border-muted); flex-wrap: wrap; gap: var(--space-2); }
  .forecast-name { font-size: 18px; font-weight: 600; }
  .forecast-name .symbol { color: var(--color-text-tertiary); font-size: 14px; font-weight: 400; font-family: var(--font-mono); margin-left: var(--space-2); }
  .star-rate { font-family: var(--font-mono); color: var(--color-warning); font-size: 16px; letter-spacing: 2px; }

  .term-row { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-3); font-family: var(--font-mono); font-size: 12px; }
  .term-row .label { color: var(--color-text-tertiary); font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; }
  .term-row .value { color: var(--color-text-primary); font-weight: 600; padding: 2px var(--space-2); background: var(--color-bg-elevated); border-radius: var(--radius-sm); }

  .scenarios-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--space-3); margin-bottom: var(--space-5); }
  @media (max-width: 720px) { .scenarios-grid { grid-template-columns: 1fr; } }
  .scenario-card { background: var(--color-bg-elevated); border-radius: var(--radius-sm); padding: var(--space-3) var(--space-4); border-left: 3px solid; }
  .scenario-card.bear { border-color: var(--color-bear); }
  .scenario-card.base { border-color: var(--color-text-secondary); }
  .scenario-card.bull { border-color: var(--color-bull); }
  .scenario-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--space-2); }
  .scenario-name { font-family: var(--font-mono); font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
  .scenario-card.bear .scenario-name { color: var(--color-bear); }
  .scenario-card.base .scenario-name { color: var(--color-text-secondary); }
  .scenario-card.bull .scenario-name { color: var(--color-bull); }
  .scenario-price { font-family: var(--font-mono); font-size: 18px; font-weight: 700; }
  .scenario-card.bear .scenario-price { color: var(--color-bear); }
  .scenario-card.base .scenario-price { color: var(--color-text-primary); }
  .scenario-card.bull .scenario-price { color: var(--color-bull); }
  .scenario-condition { font-size: 12px; color: var(--color-text-secondary); line-height: 1.55; padding-top: var(--space-2); border-top: 1px dashed var(--color-border-muted); }
  .scenario-condition .if-label { font-family: var(--font-mono); font-size: 10px; color: var(--color-text-tertiary); margin-right: var(--space-1); letter-spacing: 0.06em; }

  .reasoning-block { margin-top: var(--space-4); padding: var(--space-4); border-radius: var(--radius-sm); background: var(--color-bg-elevated); border-left: 3px solid; }
  .reasoning-block + .reasoning-block { margin-top: var(--space-3); }
  .reasoning-block.premise { border-color: var(--color-text-tertiary); }
  .reasoning-block.reason { border-color: var(--color-accent); }
  .reasoning-block.risks { border-color: var(--color-bear); }
  .reasoning-label { font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: var(--space-2); display: block; }
  .reasoning-block.premise .reasoning-label { color: var(--color-text-secondary); }
  .reasoning-block.reason .reasoning-label { color: var(--color-accent); }
  .reasoning-block.risks .reasoning-label { color: var(--color-bear); }
  .reasoning-text { color: var(--color-text-primary); font-size: 13px; line-height: 1.7; }

  /* Reference */
  .reference-section { margin-top: var(--space-7); padding-top: var(--space-5); border-top: 1px solid var(--color-border-subtle); }
  .reference-list { list-style: none; padding: 0; }
  .reference-list li { padding: var(--space-2) 0; border-bottom: 1px solid var(--color-border-muted); font-size: 13px; color: var(--color-text-secondary); }
  .reference-list li:last-child { border-bottom: none; }
  .reference-list a { color: var(--color-accent); text-decoration: none; word-break: break-all; }
  .reference-list a:hover { text-decoration: underline; }
  .reference-list .source-type { display: inline-block; font-family: var(--font-mono); font-size: 10px; padding: 1px 6px; border: 1px solid var(--color-border-subtle); border-radius: 3px; color: var(--color-text-tertiary); margin-right: var(--space-2); text-transform: uppercase; }

  footer { margin-top: var(--space-6); padding-top: var(--space-4); border-top: 1px solid var(--color-border-subtle); color: var(--color-text-tertiary); font-size: 11px; font-family: var(--font-mono); text-align: center; }
  footer a { color: var(--color-text-tertiary); text-decoration: none; }
  footer a:hover { color: var(--color-accent); }
</style>
</head>
<body>
<div class="container">

  <div class="top-bar">
    <a class="back-link" href="../index.html">← Finance Reports</a>
  </div>

  <header>
    <div>
      <div class="symbol-badge">{{ meta.primary_symbol }}</div>
      <h1 class="report-title">{{ meta.report_title }}</h1>
      <div class="report-meta">
        {% if meta.exchange %}{{ meta.exchange }}: {{ meta.primary_symbol }}{% endif %}
        {% if meta.exchange and meta.sector %} &nbsp;·&nbsp; {% endif %}
        {% if meta.sector %}{{ meta.sector }}{% endif %}
      </div>
    </div>
    <div class="header-right">
      <div class="date-label">{{ meta.report_date }} {{ meta.timezone }}</div>
    </div>
  </header>

  <div class="overview-section">
    <div class="section-title">Overview</div>
    <p class="market-description">{{ overview.market_description }}</p>
  </div>

  {# === LAYER 1: FACTS === #}
  <section class="layer-section layer-facts">
    <div class="layer-header">
      <div class="layer-tag">FACTS</div>
      <div class="layer-subtitle">客観データ・実績値</div>
    </div>

    {# Metric Cards #}
    {% if facts.metric_cards %}
    <div class="subsection">
      <div class="subsection-title">Key Metrics</div>
      <div class="metrics-grid">
        {% for card in facts.metric_cards %}
        <div class="metric-card">
          <div class="metric-label">{{ card.label }}</div>
          <div class="metric-value{% if card.size == 'small' %} small{% endif %}{% if card.tone %} {{ card.tone }}{% endif %}">
            {{ card.value }}{% if card.unit %}<span class="unit">{{ card.unit }}</span>{% endif %}
          </div>
          {% if card.sub %}<div class="metric-sub">{{ card.sub }}</div>{% endif %}
          {% if card.comparison %}
          <div class="metric-comparison">
            <span class="comparison-label">{{ card.comparison.label }}</span>
            <span class="comparison-value-block">
              <span class="comparison-value">{{ card.comparison.value }}</span>
              {% if card.comparison.delta %}<span class="comparison-delta{% if card.comparison.tone %} {{ card.comparison.tone }}{% endif %}">{{ card.comparison.delta }}</span>{% endif %}
            </span>
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}

    {# Historical Trends (Price + Revenue Charts) #}
    {% if facts.price_chart or facts.revenue_chart %}
    <div class="subsection">
      <div class="subsection-title">Historical Trends</div>
      <div class="two-col">
        {% if facts.price_chart %}
        <div class="chart-section">
          <div class="card-title">{{ facts.price_chart.title }}</div>
          <div class="chart-wrapper"><canvas id="priceChart"></canvas></div>
        </div>
        {% endif %}
        {% if facts.revenue_chart %}
        <div class="chart-section">
          <div class="card-title">{{ facts.revenue_chart.title }}</div>
          <div class="chart-wrapper"><canvas id="revenueChart"></canvas></div>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {# Comparing #}
    {% if overview.issues %}
    <div class="subsection">
      <div class="subsection-title">Comparing</div>
      <div class="table-wrapper">
        <table class="issues-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Symbol</th>
              <th style="text-align: right;">Price</th>
              <th style="text-align: right;">Market Cap</th>
              <th style="text-align: right;">Rev Growth</th>
              <th>Products</th>
              <th>Features</th>
            </tr>
          </thead>
          <tbody>
            {% for issue in overview.issues %}
            <tr class="role-{{ issue.role }}">
              <td>
                <span class="role-tag {{ issue.role }}">{% if issue.role == 'target' %}trgt{% else %}{{ issue.role }}{% endif %}</span>{{ issue.name }}
              </td>
              <td class="symbol-mono">{{ issue.symbol }}</td>
              <td class="num-mono">{{ issue.price }}<span class="unit">{{ issue.currency_override or meta.primary_currency }}</span></td>
              <td class="num-mono">
                {% if issue.market_cap is not none %}
                  {{ issue.market_cap }}<span class="unit">{{ issue.currency_override or meta.primary_currency }}</span>
                {% else %}
                  <span class="unit">—</span>
                {% endif %}
              </td>
              <td class="growth-cell{% if issue.revenue_growth_tone %} {{ issue.revenue_growth_tone }}{% endif %}">
                {{ issue.revenue_growth or '—' }}
              </td>
              <td class="products-cell">{{ issue.products or '—' }}</td>
              <td class="features-cell">{{ issue.features }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>
      <div class="scroll-hint">← → スクロールで全列表示</div>
    </div>
    {% endif %}
  </section>

  {# === LAYER 2: INSIGHTS === #}
  {% if insights.highlights %}
  <section class="layer-section layer-insights">
    <div class="layer-header">
      <div class="layer-tag">INSIGHTS</div>
      <div class="layer-subtitle">事実観察・複合的解釈</div>
    </div>

    <div class="highlights-card">
      <ul class="highlights-list">
        {% for hl in insights.highlights %}
        <li class="highlight-item level-{{ hl.level }}">
          <span class="level-marker">{% if hl.level == 'info' %}i{% elif hl.level == 'warning' %}!{% elif hl.level == 'danger' %}×{% endif %}</span>
          {% if hl.name %}<span class="highlight-name">{{ hl.name }}:</span>{% endif %}
          <span class="highlight-text">{{ hl.text }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
  </section>
  {% endif %}

  {# === LAYER 3: ANALYSIS === #}
  <section class="layer-section layer-analysis">
    <div class="layer-header">
      <div class="layer-tag">ANALYSIS</div>
      <div class="layer-subtitle">主観的評価・予想（参考）</div>
    </div>

    {# Scores #}
    {% if analysis.scores %}
    <div class="subsection">
      <div class="subsection-title">Scores (Subjective)</div>
      <div class="scores-card">
        <div class="scores-grid">
          {# Split scores into 2 columns (left=first half, right=second half) #}
          {% set half = (analysis.scores | length + 1) // 2 %}
          <div>
            {% for score in analysis.scores[:half] %}
            {% set pct = (score.value / score.scale_max * 100) | round | int %}
            {% if score.tone == 'bull' %}{% set color_var = '--color-bull' %}
            {% elif score.tone == 'bear' %}{% set color_var = '--color-bear' %}
            {% elif score.tone == 'warning' %}{% set color_var = '--color-warning' %}
            {% else %}{% set color_var = '--color-accent' %}{% endif %}
            <div class="score-row">
              <span class="score-label">{{ score.label }}</span>
              <span class="score-val{% if score.tone %} {{ score.tone }}{% endif %}">{{ score.value }} / {{ score.scale_max }}</span>
            </div>
            <div class="bar-track"><div class="bar-fill" data-width="{{ pct }}" data-color-var="{{ color_var }}"></div></div>
            {% endfor %}
          </div>
          <div>
            {% for score in analysis.scores[half:] %}
            {% set pct = (score.value / score.scale_max * 100) | round | int %}
            {% if score.tone == 'bull' %}{% set color_var = '--color-bull' %}
            {% elif score.tone == 'bear' %}{% set color_var = '--color-bear' %}
            {% elif score.tone == 'warning' %}{% set color_var = '--color-warning' %}
            {% else %}{% set color_var = '--color-accent' %}{% endif %}
            <div class="score-row">
              <span class="score-label">{{ score.label }}</span>
              <span class="score-val{% if score.tone %} {{ score.tone }}{% endif %}">{{ score.value }} / {{ score.scale_max }}</span>
            </div>
            <div class="bar-track"><div class="bar-fill" data-width="{{ pct }}" data-color-var="{{ color_var }}"></div></div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    {% endif %}

    {# Forecast #}
    {% if analysis.forecasts %}
    <div class="subsection">
      <div class="subsection-title">Forecast</div>
      {% for fc in analysis.forecasts %}
      <div class="forecast-card">
        <div class="forecast-header">
          <div class="forecast-name">{{ fc.name }}<span class="symbol">{{ fc.symbol }}</span></div>
          <div class="star-rate" title="Rate: {{ fc.rate }}/5">
            {% for _ in range(fc.rate) %}★{% endfor %}{% for _ in range(5 - fc.rate) %}☆{% endfor %}
          </div>
        </div>

        {% if fc.strategy.term %}
        <div class="term-row">
          <span class="label">Term</span>
          <span class="value">{{ fc.strategy.term }}</span>
        </div>
        {% endif %}

        <div class="scenarios-grid">
          {% for key in ['bear', 'base', 'bull'] %}
          {% set sc = fc.strategy.forecast[key] %}
          {% if sc %}
          <div class="scenario-card {{ key }}">
            <div class="scenario-head">
              <div class="scenario-name">{{ key }}</div>
              <div class="scenario-price">{{ sc.price }}<span class="unit">{{ sc.currency }}</span></div>
            </div>
            {% if sc.condition %}
            <div class="scenario-condition">
              <span class="if-label">If</span>{{ sc.condition }}
            </div>
            {% endif %}
          </div>
          {% endif %}
          {% endfor %}
        </div>

        {% if fc.premise %}
        <div class="reasoning-block premise">
          <span class="reasoning-label">Premise</span>
          <div class="reasoning-text">{{ fc.premise }}</div>
        </div>
        {% endif %}
        {% if fc.reason %}
        <div class="reasoning-block reason">
          <span class="reasoning-label">Reason</span>
          <div class="reasoning-text">{{ fc.reason }}</div>
        </div>
        {% endif %}
        {% if fc.risks %}
        <div class="reasoning-block risks">
          <span class="reasoning-label">Risks</span>
          <div class="reasoning-text">{{ fc.risks }}</div>
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    {% endif %}
  </section>

  {# === Reference === #}
  {% if reference.sources %}
  <div class="reference-section">
    <div class="section-title">Reference</div>
    <ul class="reference-list">
      {% for src in reference.sources %}
      <li>
        <span class="source-type">{{ src.type }}</span>
        {% if src.url %}
          <a href="{{ src.url }}" target="_blank" rel="noopener">{{ src.title or src.url }}</a>
        {% else %}
          {{ src.description }}
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <footer>
    <a href="../index.html">← Finance Reports</a>
    &nbsp;·&nbsp; {{ report_id }} &nbsp;·&nbsp; Generated {{ meta.report_date }} {{ meta.timezone }}
  </footer>

</div>

<script id="charts-data" type="application/json">{{ charts_json | safe }}</script>

<script>
// Apply score bar widths and colors from data-* attributes
(function() {
  document.querySelectorAll('.bar-fill').forEach(el => {
    const width = el.dataset.width;
    const colorVar = el.dataset.colorVar;
    if (width) el.style.width = width + '%';
    if (colorVar) el.style.background = 'var(' + colorVar + ')';
  });
})();

// Render charts from JSON payload
(function() {
  const dataEl = document.getElementById('charts-data');
  if (!dataEl) return;
  const charts = JSON.parse(dataEl.textContent);

  const textColor = '#8b949e';
  const gridColor = '#21262d';
  const tooltipBg = '#1c2128';
  const monoSm = { family: 'JetBrains Mono, monospace', size: 10 };
  const monoMd = { family: 'JetBrains Mono, monospace', size: 11 };

  // Price Chart (line)
  if (charts.price_chart) {
    const pc = charts.price_chart;
    const ctx = document.getElementById('priceChart');
    if (ctx) {
      new Chart(ctx, {
        type: 'line',
        data: {
          labels: pc.labels,
          datasets: [{
            label: pc.dataset_label,
            data: pc.data,
            borderColor: '#58a6ff',
            backgroundColor: 'rgba(88,166,255,0.08)',
            borderWidth: 2, pointRadius: 3, pointBackgroundColor: '#58a6ff',
            tension: 0.35, fill: true
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: { labels: { color: textColor, font: monoMd } },
            tooltip: { backgroundColor: tooltipBg, borderColor: gridColor, borderWidth: 1, titleColor: '#e6edf3', bodyColor: textColor,
              callbacks: { label: (ctx) => ' ' + (pc.currency_prefix || '') + ctx.parsed.y.toLocaleString() + (pc.currency_suffix || '') } }
          },
          scales: {
            x: { grid: { color: gridColor }, ticks: { color: '#6e7681', font: monoSm } },
            y: { grid: { color: gridColor },
              ticks: { color: '#6e7681', font: monoSm,
                callback: (v) => (pc.currency_prefix || '') + v.toLocaleString() + (pc.currency_suffix || '') } }
          }
        }
      });
    }
  }

  // Revenue Chart (bar, 3-series)
  if (charts.revenue_chart) {
    const rc = charts.revenue_chart;
    const ctx = document.getElementById('revenueChart');
    if (ctx) {
      const colors = ['#58a6ff', '#26a69a', '#d29922'];
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: rc.labels,
          datasets: rc.datasets.map((ds, i) => ({
            label: ds.label,
            data: ds.data,
            backgroundColor: colors[i % colors.length],
            borderRadius: 2
          }))
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: { position: 'top', align: 'end',
              labels: { color: textColor, boxWidth: 10, boxHeight: 10, padding: 12, font: monoMd } },
            tooltip: { backgroundColor: tooltipBg, borderColor: gridColor, borderWidth: 1, titleColor: '#e6edf3', bodyColor: textColor,
              callbacks: { label: (ctx) => ' ' + ctx.dataset.label + ': $' + ctx.parsed.y.toLocaleString() + 'B' } }
          },
          scales: {
            x: { grid: { display: false }, ticks: { color: '#6e7681', font: monoSm } },
            y: { grid: { color: gridColor },
              ticks: { color: '#6e7681', font: monoSm, callback: (v) => '$' + v + 'B' } }
          }
        }
      });
    }
  }
})();
</script>

</body>
</html>
